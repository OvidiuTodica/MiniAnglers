{%- comment -%} MiniAnglers "Why" feature band (RO default, EN via data-i18n) {%- endcomment -%}
{%- assign s = section.settings -%}
<section class="features section">
  <div class="features-head">
    <span class="eyebrow glow" data-i18n="features.eyebrow">{{ s.eyebrow | default: 'De ce MiniAnglers' }}</span>
    <h2 data-i18n="features.heading">{{ s.heading | default: 'Construit pentru pescari, de pescari.' }}</h2>
  </div>
  <div class="features-grid">
    <div class="feature">
      <span class="feature-ic">{% render 'ma-icon', icon: 'check' %}</span>
      <h3 data-i18n="features.t1">Imprimat 3D în casă</h3>
      <p data-i18n="features.d1">Control total al calității, fără intermediari.</p>
    </div>
    <div class="feature">
      <span class="feature-ic">{% render 'ma-icon', icon: 'check' %}</span>
      <h3 data-i18n="features.t2">Gravare gratuită</h3>
      <p data-i18n="features.d2">Numele tău pe fiecare cutie, fără cost suplimentar.</p>
    </div>
    <div class="feature">
      <span class="feature-ic">{% render 'ma-icon', icon: 'check' %}</span>
      <h3 data-i18n="features.t3">Sistem modular</h3>
      <p data-i18n="features.d3">Piese care se fixează exact pe tava ta laterală.</p>
    </div>
    <div class="feature">
      <span class="feature-ic">{% render 'ma-icon', icon: 'check' %}</span>
      <h3 data-i18n="features.t4">Rezistent pe mal</h3>
      <p data-i18n="features.d4">Materiale alese să țină pe teren, sezon după sezon.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why band",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "De ce MiniAnglers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Construit pentru pescari, de pescari." }
  ],
  "presets": [{ "name": "Why band" }]
}
{% endschema %}
