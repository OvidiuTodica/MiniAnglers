{%- comment -%} MiniAnglers hero (RO default, EN via data-i18n) {%- endcomment -%}
{%- assign s = section.settings -%}
<header class="hero">
  <div class="hero-left reveal" style="animation-delay:.05s">
    <span class="eyebrow" data-i18n="hero.eyebrow">{{ s.eyebrow | default: 'Sistem Modular de Pescuit' }}</span>
    <h1>
      <span data-i18n="hero.line1">{{ s.line_1 | default: 'Organizat.' }}</span><br>
      <span data-i18n="hero.line2">{{ s.line_2 | default: 'Precis.' }}</span><br>
      <span class="muted" data-i18n="hero.line3">{{ s.line_3 | default: 'Personalizat.' }}</span>
    </h1>
    <p class="hero-sub" data-i18n="hero.sub">{{ s.subtext | default: 'Pune capăt haosului de pe tava laterală. Cutii pentru momeală și suporturi pentru wafters proiectate cu precizie, construite exact după setarea și stilul tău.' }}</p>
    <div class="hero-cta">
      <a class="btn btn-glass btn-lg" href="{{ s.cta1_link | default: '#products' }}">{% render 'ma-icon', icon: 'sliders' %} <span data-i18n="hero.cta1">{{ s.cta1_label | default: 'Începe Personalizarea' }}</span></a>
      <a class="btn btn-ghost btn-lg" href="{{ s.cta2_link | default: '#products' }}"><span data-i18n="hero.cta2">{{ s.cta2_label | default: 'Explorează sistemul' }}</span></a>
    </div>
    <div class="hero-stats">
      <div><div class="stat-n" data-i18n="hero.stat1n">{{ s.stat1_n | default: 'Imprimat 3D' }}</div><div class="stat-l" data-i18n="hero.stat1l">{{ s.stat1_l | default: 'În casă' }}</div></div>
      <div><div class="stat-n" data-i18n="hero.stat2n">{{ s.stat2_n | default: 'Gravat' }}</div><div class="stat-l" data-i18n="hero.stat2l">{{ s.stat2_l | default: 'Numele tău' }}</div></div>
      <div><div class="stat-n" data-i18n="hero.stat3n">{{ s.stat3_n | default: '∞' }}</div><div class="stat-l" data-i18n="hero.stat3l">{{ s.stat3_l | default: 'Configurații' }}</div></div>
    </div>
  </div>

  <div class="showcase reveal" style="animation-delay:.18s">
    {%- if s.image != blank -%}
      <img class="showcase-photo" src="{{ s.image | image_url: width: 900 }}" alt="{{ s.image.alt | escape | default: 'Cutie modulară MiniAnglers' }}" loading="eager" width="900" height="990">
    {%- else -%}
      <div class="showcase-placeholder" aria-hidden="true">
        <div class="ph-box"><span></span><span></span><span></span><span></span><span></span><span></span></div>
      </div>
    {%- endif -%}
    <div class="showcase-scrim"></div>
    <div class="showcase-tag"><span class="glass-tag" data-i18n="hero.phototag">{{ s.photo_tag | default: 'Construcție pe Teren · Pe Mal' }}</span></div>
    <div class="showcase-spec" data-i18n="hero.spec">{{ s.spec_text | default: 'IMPRIMAT 3D · GRAVAT<br>COMPARTIMENTE MODULARE' }}</div>
  </div>
</header>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sistem Modular de Pescuit" },
    { "type": "text", "id": "line_1", "label": "Headline line 1", "default": "Organizat." },
    { "type": "text", "id": "line_2", "label": "Headline line 2", "default": "Precis." },
    { "type": "text", "id": "line_3", "label": "Headline line 3 (muted)", "default": "Personalizat." },
    { "type": "textarea", "id": "subtext", "label": "Sub text", "default": "Pune capăt haosului de pe tava laterală. Cutii pentru momeală și suporturi pentru wafters proiectate cu precizie, construite exact după setarea și stilul tău." },
    { "type": "text", "id": "cta1_label", "label": "Primary CTA label", "default": "Începe Personalizarea" },
    { "type": "text", "id": "cta1_link", "label": "Primary CTA link", "default": "#products" },
    { "type": "text", "id": "cta2_label", "label": "Secondary CTA label", "default": "Explorează sistemul" },
    { "type": "text", "id": "cta2_link", "label": "Secondary CTA link", "default": "#products" },
    { "type": "header", "content": "Showcase" },
    { "type": "image_picker", "id": "image", "label": "Product photo (optional)" },
    { "type": "text", "id": "photo_tag", "label": "Photo tag", "default": "Construcție pe Teren · Pe Mal" },
    { "type": "html", "id": "spec_text", "label": "Spec caption", "default": "IMPRIMAT 3D · GRAVAT<br>COMPARTIMENTE MODULARE" },
    { "type": "header", "content": "Stats" },
    { "type": "text", "id": "stat1_n", "label": "Stat 1 value", "default": "Imprimat 3D" },
    { "type": "text", "id": "stat1_l", "label": "Stat 1 label", "default": "În casă" },
    { "type": "text", "id": "stat2_n", "label": "Stat 2 value", "default": "Gravat" },
    { "type": "text", "id": "stat2_l", "label": "Stat 2 label", "default": "Numele tău" },
    { "type": "text", "id": "stat3_n", "label": "Stat 3 value", "default": "∞" },
    { "type": "text", "id": "stat3_l", "label": "Stat 3 label", "default": "Configurații" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
