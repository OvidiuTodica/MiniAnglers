{%- comment -%} MiniAnglers footer (RO default, EN via data-i18n) {%- endcomment -%}
{%- assign s = section.settings -%}
<footer class="footer">
  <div class="section">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="brand-word">Mini<b>Anglers</b></span>
        <div class="footer-tag" data-i18n="footer.tagline">{{ s.tagline | default: 'Sigilat. Montat. Gravat.' }}</div>
        <p class="footer-sub" data-i18n="footer.blurb">{{ s.blurb | default: 'Sisteme de pescuit de precizie pentru pescarul modern la method-feeder. Fabricat în UK.' }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.title }}</h4>
            {%- if block.settings.menu != blank -%}
              {%- for link in block.settings.menu.links -%}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        <div class="footer-col">
          <h4 data-i18n="footer.shop">Magazin</h4>
          <a href="#" data-i18n="footer.shop1">Cutii de Momeală</a><a href="#" data-i18n="footer.shop2">Suporturi Wafter</a><a href="#" data-i18n="footer.shop3">Sisteme Complete</a><a href="#" data-i18n="footer.shop4">Piese</a>
        </div>
        <div class="footer-col">
          <h4 data-i18n="footer.company">Companie</h4>
          <a href="#" data-i18n="footer.company1">Povestea Noastră</a><a href="#" data-i18n="footer.company2">Procesul</a><a href="#" data-i18n="footer.company3">Materiale</a><a href="#" data-i18n="footer.company4">Contact</a>
        </div>
      {%- endif -%}

      {%- if s.show_newsletter -%}
        <div class="footer-col">
          <h4 data-i18n="footer.news_title">{{ s.newsletter_title | default: 'Rămâi la curent' }}</h4>
          <p class="footer-sub" data-i18n="footer.news_text">{{ s.newsletter_text | default: 'Module noi și reaprovizionări, fără zgomot.' }}</p>
          {%- form 'customer' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="news">
              <input type="email" name="contact[email]" placeholder="email@exemplu.com" aria-label="Adresă de email" required>
              <button class="btn btn-steel btn-sm" type="submit" data-i18n="footer.join">Abonează-te</button>
            </div>
            {%- if form.posted_successfully? -%}<p class="footer-sub" style="margin-top:8px;color:var(--teal)">Mulțumim — ești pe listă.</p>{%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>

    <div class="footer-fine">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}. <span data-i18n="footer.rights">Toate drepturile rezervate.</span></span>
      <span data-i18n="footer.legal">Confidențialitate · Termeni · Retururi</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Sigilat. Montat. Gravat." },
    { "type": "textarea", "id": "blurb", "label": "Brand blurb", "default": "Sisteme de pescuit de precizie pentru pescarul modern la method-feeder. Fabricat în UK." },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter signup", "default": true },
    { "type": "text", "id": "newsletter_title", "label": "Newsletter title", "default": "Rămâi la curent" },
    { "type": "text", "id": "newsletter_text", "label": "Newsletter text", "default": "Module noi și reaprovizionări, fără zgomot." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title", "default": "Magazin" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ]
}
{% endschema %}
