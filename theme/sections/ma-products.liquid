{%- comment -%} MiniAnglers product grid {%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign coll = s.collection -%}
<section class="products section" id="products">
  <div class="products-head">
    <div>
      <span class="eyebrow">{{ s.eyebrow | default: 'The System' }}</span>
      <h2>{{ s.heading | default: 'Engineered modules.' }}</h2>
    </div>
    {%- if coll != blank -%}
      <a class="btn btn-ghost btn-sm" href="{{ coll.url }}">View all {% render 'ma-icon', icon: 'arrow-right' %}</a>
    {%- endif -%}
  </div>

  <div class="product-grid">
    {%- if coll != blank and coll.products.size > 0 -%}
      {%- for product in coll.products limit: s.limit -%}
        <a class="pcard" href="{{ product.url }}">
          <div class="pcard-media">
            {%- if product.metafields.custom.tag != blank -%}
              <span class="glass-tag">{{ product.metafields.custom.tag }}</span>
            {%- elsif product.type != blank -%}
              <span class="glass-tag">{{ product.type }}</span>
            {%- endif -%}
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}" loading="lazy" width="600" height="400">
            {%- else -%}
              <div class="mini-box"></div>
            {%- endif -%}
          </div>
          <div class="pcard-body">
            <h3>{{ product.title }}</h3>
            <p>{{ product.description | strip_html | truncatewords: 14 }}</p>
            <div class="pcard-foot">
              {%- if s.show_prices -%}
                <span class="pcard-price">{{ product.price | money }}</span>
              {%- else -%}
                <span class="pcard-meta">Coming soon</span>
              {%- endif -%}
              <span class="btn btn-glass btn-sm">View</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Brute fallback: placeholder cards, no real products yet {%- endcomment -%}
      {%- assign tags = 'Bait Box · 6-Bay,Bait-Pot Holder,Full System' | split: ',' -%}
      {%- assign titles = 'The Modular Six,Edge Mount Pro,The Bank Kit' | split: ',' -%}
      {%- assign descs = 'Six open compartments, angled dividers, engraved rim.|Holds three clear bait pots, locks onto your side tray.|Bait box, pot holder and a snap-fit alignment rail.' | split: '|' -%}
      {%- for t in titles -%}
        <article class="pcard">
          <div class="pcard-media">
            <span class="glass-tag">{{ tags[forloop.index0] }}</span>
            <div class="mini-box"></div>
          </div>
          <div class="pcard-body">
            <h3>{{ t }}</h3>
            <p>{{ descs[forloop.index0] }}</p>
            <div class="pcard-foot">
              <span class="pcard-meta">Coming soon</span>
              <span class="btn btn-glass btn-sm">View</span>
            </div>
          </div>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The System" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Engineered modules." },
    { "type": "collection", "id": "collection", "label": "Collection (leave empty for placeholders)" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 3, "max": 12, "step": 3, "default": 3 },
    { "type": "checkbox", "id": "show_prices", "label": "Show prices", "default": false }
  ],
  "presets": [{ "name": "Product grid" }]
}
{% endschema %}
