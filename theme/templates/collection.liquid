{%- comment -%} Minimal branded collection grid (round one). {%- endcomment -%}
<div class="page-wrap">
  <span class="eyebrow">{{ collection.metafields.custom.eyebrow | default: 'Collection' }}</span>
  <h1>{{ collection.title }}</h1>
  {%- if collection.description != blank -%}<p style="color:var(--steel-400);max-width:560px;margin-bottom:18px">{{ collection.description }}</p>{%- endif -%}

  <div class="product-grid" style="margin-top:24px">
    {%- for product in collection.products -%}
      <a class="pcard" href="{{ product.url }}">
        <div class="pcard-media">
          {%- if product.type != blank -%}<span class="glass-tag">{{ product.type }}</span>{%- endif -%}
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}" loading="lazy">
          {%- else -%}<div class="mini-box"></div>{%- endif -%}
        </div>
        <div class="pcard-body">
          <h3>{{ product.title }}</h3>
          <p>{{ product.description | strip_html | truncatewords: 14 }}</p>
          <div class="pcard-foot">
            <span class="pcard-price">{{ product.price | money }}</span>
            <span class="btn btn-glass btn-sm">View</span>
          </div>
        </div>
      </a>
    {%- else -%}
      <p style="color:var(--steel-500)">No products yet.</p>
    {%- endfor -%}
  </div>
</div>
