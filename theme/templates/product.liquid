{%- comment -%}
  MiniAnglers product page (RO default, EN via data-i18n).
  Personalization lives here: choose the product, add a free engraving
  with a live preview, then add to cart. Engraving = line item property.
{%- endcomment -%}
<div class="product-page page-wrap">
  <a class="eyebrow" href="{{ routes.all_products_collection_url }}" data-i18n="product.back">← Toate produsele</a>

  <div class="product-layout">
    <div class="product-media">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}" width="900" height="900">
      {%- else -%}
        <div class="product-media-ph" aria-hidden="true"><div class="mini-box"></div></div>
      {%- endif -%}
    </div>

    <div class="product-info">
      <h1>{{ product.title }}</h1>
      <div class="product-price">{{ product.price | money }}</div>
      {%- if product.description != blank -%}
        <div class="product-desc">{{ product.description }}</div>
      {%- endif -%}

      {%- form 'product', product -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="form-field">
              <label for="opt-{{ forloop.index }}">{{ option.name }}</label>
              <select class="cfg-input" id="opt-{{ forloop.index }}" name="options[{{ option.name | escape }}]">
                {%- for value in option.values -%}<option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>{%- endfor -%}
              </select>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- comment -%} Engraving widget {%- endcomment -%}
        <div class="engrave" data-product-engrave data-max="16">
          <div class="engrave-head">
            <span class="l" data-i18n="config.engraving">Gravare</span>
            <span class="v" data-eng-count>Gratuit · 0/16</span>
          </div>
          <input class="cfg-input" data-eng-input type="text" maxlength="16"
                 name="properties[Engraving]" placeholder="Numele tău"
                 data-i18n-ph="config.placeholder" aria-label="Text gravură">

          <div class="engrave-preview">
            <span class="glass-tag" data-i18n="product.preview">Previzualizare gravură</span>
            <div class="engrave-plate" data-eng-etch>NUMELE TĂU AICI</div>
          </div>
        </div>

        <button type="submit" class="btn btn-steel btn-lg product-add" {% unless product.available %}disabled{% endunless %}>
          {% render 'ma-icon', icon: 'plus' %}
          {%- if product.available -%}<span data-i18n="product.add">Adaugă în coș</span>{%- else -%}<span data-i18n="product.soldout">Stoc epuizat</span>{%- endif -%}
        </button>
      {%- endform -%}
    </div>
  </div>
</div>
