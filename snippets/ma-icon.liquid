{%- comment -%}
  MiniAnglers inline icon. Usage: {% render 'ma-icon', icon: 'search' %}
  Available: search, cart, sliders, plus, arrow-right, check
{%- endcomment -%}
{%- liquid
  case icon
    when 'search'
      assign paths = '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>'
    when 'cart'
      assign paths = '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>'
    when 'sliders'
      assign paths = '<line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/>'
    when 'plus'
      assign paths = '<path d="M5 12h14"/><path d="M12 5v14"/>'
    when 'arrow-right'
      assign paths = '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>'
    when 'check'
      assign paths = '<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>'
    when 'menu'
      assign paths = '<line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>'
    when 'close'
      assign paths = '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>'
    when 'mail'
      assign paths = '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>'
    when 'box'
      assign paths = '<path d="M21 8 12 3 3 8v8l9 5 9-5V8Z"/><path d="M3 8l9 5 9-5"/><path d="M12 13v9"/>'
    when 'layers'
      assign paths = '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>'
    when 'shield'
      assign paths = '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>'
    else
      assign paths = ''
  endcase
-%}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">{{ paths }}</svg>
