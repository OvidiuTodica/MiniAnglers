{%- comment -%} MiniAnglers hero — simple, centered, product-focused (RO default, EN via data-i18n) {%- endcomment -%}
{%- assign s = section.settings -%}
<header class="hero" id="sistem">
  <span class="eyebrow" data-i18n="hero.eyebrow">{{ s.eyebrow | default: 'Sistem Modular de Pescuit' }}</span>
  <h1>
    <span data-i18n="hero.line1">{{ s.line_1 | default: 'Organizat.' }}</span>
    <span data-i18n="hero.line2">{{ s.line_2 | default: 'Precis.' }}</span>
    <span class="muted" data-i18n="hero.line3">{{ s.line_3 | default: 'Personalizat.' }}</span>
  </h1>
  <p class="hero-sub" data-i18n="hero.sub">{{ s.subtext | default: 'Bacuri de nadă și suporturi pentru wafters și gel, imprimate 3D. Gravare personalizată disponibilă cu numele tău.' }}</p>
  <div class="hero-cta">
    <a class="btn btn-glass btn-lg" href="{{ s.cta1_link | default: '#cutii' }}"><span data-i18n="hero.cta1">{{ s.cta1_label | default: 'Vezi produsele' }}</span></a>
  </div>
</header>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sistem Modular de Pescuit" },
    { "type": "text", "id": "line_1", "label": "Headline line 1", "default": "Organizat." },
    { "type": "text", "id": "line_2", "label": "Headline line 2", "default": "Precis." },
    { "type": "text", "id": "line_3", "label": "Headline line 3 (accent)", "default": "Personalizat." },
    { "type": "textarea", "id": "subtext", "label": "Sub text", "default": "Bacuri de nadă și suporturi pentru wafters și gel, imprimate 3D. Gravare personalizată disponibilă cu numele tău." },
    { "type": "text", "id": "cta1_label", "label": "CTA label", "default": "Vezi produsele" },
    { "type": "text", "id": "cta1_link", "label": "CTA link", "default": "#cutii" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
