{%- comment -%} MiniAnglers process — 4 steps (RO default, EN via data-i18n) {%- endcomment -%}
{%- assign s = section.settings -%}
<section class="steps" id="proces">
  <div class="section">
    <div class="shead">
      <h2 data-i18n="steps.heading">{{ s.heading | default: 'De la fișier la mal' }}</h2>
      <span class="mono" data-i18n="steps.ref">{{ s.ref | default: 'PROCES · 04 PAȘI' }}</span>
    </div>
    <div class="steps-grid">
      <div class="step"><div class="step-n">01</div><h4 data-i18n="steps.t1">{{ s.t1 | default: 'Alegi cutia' }}</h4><p data-i18n="steps.d1">{{ s.d1 | default: 'Bacuri, suport de wafters sau gel — alege ce ți se potrivește.' }}</p></div>
      <div class="step"><div class="step-n">02</div><h4 data-i18n="steps.t2">{{ s.t2 | default: 'Scrii gravura' }}</h4><p data-i18n="steps.d2">{{ s.d2 | default: 'Numele, clubul sau codul echipei. Gratuit, până la 16 caractere.' }}</p></div>
      <div class="step"><div class="step-n">03</div><h4 data-i18n="steps.t3">{{ s.t3 | default: 'Imprimăm 3D' }}</h4><p data-i18n="steps.d3">{{ s.d3 | default: 'Strat cu strat, în casă, cu toleranțe de inginerie.' }}</p></div>
      <div class="step"><div class="step-n">04</div><h4 data-i18n="steps.t4">{{ s.t4 | default: 'Ajunge la tine' }}</h4><p data-i18n="steps.d4">{{ s.d4 | default: 'Gata de pescuit, exact după setarea ta.' }}</p></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Process",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "De la fișier la mal" },
    { "type": "text", "id": "ref", "label": "Reference label", "default": "PROCES · 04 PAȘI" },
    { "type": "text", "id": "t1", "label": "Step 1 title", "default": "Alegi cutia" },
    { "type": "textarea", "id": "d1", "label": "Step 1 text", "default": "Bacuri, suport de wafters sau gel — alege ce ți se potrivește." },
    { "type": "text", "id": "t2", "label": "Step 2 title", "default": "Scrii gravura" },
    { "type": "textarea", "id": "d2", "label": "Step 2 text", "default": "Numele, clubul sau codul echipei. Gratuit, până la 16 caractere." },
    { "type": "text", "id": "t3", "label": "Step 3 title", "default": "Imprimăm 3D" },
    { "type": "textarea", "id": "d3", "label": "Step 3 text", "default": "Strat cu strat, în casă, cu toleranțe de inginerie." },
    { "type": "text", "id": "t4", "label": "Step 4 title", "default": "Ajunge la tine" },
    { "type": "textarea", "id": "d4", "label": "Step 4 text", "default": "Gata de pescuit, exact după setarea ta." }
  ],
  "presets": [{ "name": "Process" }]
}
{% endschema %}
