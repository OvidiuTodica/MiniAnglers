{%- comment -%} MiniAnglers engraving callout — paid add-on (RO default, EN via data-i18n) {%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign eng_product = settings.engraving_product -%}
{%- if eng_product != blank -%}
  {%- assign eng_variant = eng_product.selected_or_first_available_variant -%}
{%- endif -%}
{%- if eng_variant != blank and eng_variant.available -%}
  {%- assign eng_price_display = eng_variant.price | money -%}
{%- else -%}
  {%- assign eng_price_display = settings.engraving_price_note | default: '+19 lei' -%}
{%- endif -%}
<section class="callout-sec" id="gravare">
  <div class="section">
    <div class="callout">
      <div>
        <h2 data-i18n="engrave.heading">{{ s.heading | default: 'Gravare personalizată.' }}</h2>
        <p data-i18n="engrave.text">{{ s.text | default: 'Numele tău, clubul sau codul echipei, gravat direct pe ramă. Se adaugă ca opțiune la finalizarea comenzii.' }}</p>
        <span class="mono"><span data-i18n="engrave.price_label">{{ s.price_label | default: 'Gravare' }}</span>: {{ eng_price_display }}</span>
      </div>
      <div class="field">{{ s.sample | default: 'TODICA · 2026' }}</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Engraving callout",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Gravare personalizată." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Numele tău, clubul sau codul echipei, gravat direct pe ramă. Se adaugă ca opțiune la finalizarea comenzii." },
    { "type": "text", "id": "price_label", "label": "Price label", "default": "Gravare" },
    { "type": "text", "id": "sample", "label": "Sample engraving", "default": "TODICA · 2026" }
  ],
  "presets": [{ "name": "Engraving callout" }]
}
{% endschema %}
