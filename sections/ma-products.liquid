{%- comment -%} MiniAnglers product grid (RO default, EN via data-i18n) {%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign coll = s.collection -%}
<section class="products section" id="products">
  <div class="products-head">
    <div>
      <span class="eyebrow" data-i18n="products.eyebrow">{{ s.eyebrow | default: 'Sistemul' }}</span>
      <h2 data-i18n="products.heading">{{ s.heading | default: 'Module inginerești.' }}</h2>
    </div>
    {%- if coll != blank -%}
      <a class="btn btn-ghost btn-sm" href="{{ coll.url }}"><span data-i18n="products.viewall">Vezi tot</span> {% render 'ma-icon', icon: 'arrow-right' %}</a>
    {%- endif -%}
  </div>

  <div class="product-grid">
    {%- if coll != blank and coll.products.size > 0 -%}
      {%- for product in coll.products limit: s.limit -%}
        <a class="pcard" href="{{ product.url }}">
          <div class="pcard-media">
            {%- if product.metafields.custom.tag != blank -%}
              <span class="glass-tag">{{ product.metafields.custom.tag }}</span>
            {%- elsif product.type != blank -%}
              <span class="glass-tag">{{ product.type }}</span>
            {%- endif -%}
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}" loading="lazy" width="600" height="400">
            {%- else -%}
              <div class="mini-box"></div>
            {%- endif -%}
          </div>
          <div class="pcard-body">
            <h3>{{ product.title }}</h3>
            <p>{{ product.description | strip_html | truncatewords: 14 }}</p>
            <div class="pcard-foot">
              {%- if s.show_prices -%}
                <span class="pcard-price">{{ product.price | money }}</span>
              {%- else -%}
                <span class="pcard-meta" data-i18n="products.soon">În curând</span>
              {%- endif -%}
              <span class="btn btn-glass btn-sm" data-i18n="products.view">Vezi</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Brute fallback: placeholder cards (titles are brand names, kept untranslated) {%- endcomment -%}
      {%- assign titles = 'The Modular Six,Edge Mount Pro,The Bank Kit' | split: ',' -%}
      {%- assign tags = 'Cutie Momeală · 6 Compartimente,Suport Borcan Momeală,Sistem Complet' | split: ',' -%}
      {%- assign descs = 'Șase compartimente deschise, separatoare unghiulare, ramă gravată.|Ține trei borcane transparente, se fixează pe tava laterală.|Cutie de momeală, suport de borcane și o șină de aliniere snap-fit.' | split: '|' -%}
      {%- for t in titles -%}
        <article class="pcard">
          <div class="pcard-media">
            <span class="glass-tag" data-i18n="products.tag{{ forloop.index }}">{{ tags[forloop.index0] }}</span>
            <div class="mini-box"></div>
          </div>
          <div class="pcard-body">
            <h3>{{ t }}</h3>
            <p data-i18n="products.desc{{ forloop.index }}">{{ descs[forloop.index0] }}</p>
            <div class="pcard-foot">
              <span class="pcard-meta" data-i18n="products.soon">În curând</span>
              <span class="btn btn-glass btn-sm" data-i18n="products.view">Vezi</span>
            </div>
          </div>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sistemul" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Module inginerești." },
    { "type": "collection", "id": "collection", "label": "Collection (leave empty for placeholders)" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 3, "max": 12, "step": 3, "default": 3 },
    { "type": "checkbox", "id": "show_prices", "label": "Show prices", "default": false }
  ],
  "presets": [{ "name": "Product grid" }]
}
{% endschema %}
