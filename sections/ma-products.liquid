{%- comment -%} MiniAnglers products — spec cards with product picker + fallback (RO default, EN via data-i18n) {%- endcomment -%}
{%- assign s = section.settings -%}
<section class="products" id="cutii">
  <div class="section">
    <div class="shead">
      <h2 data-i18n="products.heading">{{ s.heading | default: 'Produsele. Date reale, imprimate 3D.' }}</h2>
      <span class="mono">{{ s.ref | default: 'REF. 01–03' }}</span>
    </div>

    <div class="grid3">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        {%- assign p = b.product -%}
        <article class="card" {{ block.shopify_attributes }}>
          <div class="top">
            <span class="name">{% if p != blank %}{{ p.title }}{% else %}{{ b.name }}{% endif %}</span>
            <span class="pn">{{ b.pn }}</span>
          </div>

          <div class="viz">
            {%- if p != blank and p.featured_image != blank -%}
              <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.featured_image.alt | escape | default: p.title }}" loading="lazy">
            {%- else -%}
              <div class="shape">
                {%- case b.shape -%}
                  {%- when 'bar_long' -%}
                    <b style="width:88%;height:30%"></b>
                  {%- when 'bar_small' -%}
                    <b style="width:36%;height:34%"></b>
                  {%- else -%}
                    <b style="width:42%;height:100%"></b><b style="width:30%;height:78%"></b><b style="width:20%;height:62%"></b><b style="width:10%;height:48%"></b>
                {%- endcase -%}
              </div>
            {%- endif -%}
          </div>

          <div class="body">
            <h3>{% if p != blank %}{{ p.title }}{% else %}{{ b.name }}{% endif %}</h3>
            <p>{% if p != blank and p.description != blank %}{{ p.description | strip_html | truncatewords: 22 }}{% else %}{{ b.desc }}{% endif %}</p>

            <ul class="spec">
              {%- if b.spec1_k != blank -%}<li><span class="k">{{ b.spec1_k }}</span><span class="val">{{ b.spec1_v }}</span></li>{%- endif -%}
              {%- if b.spec2_k != blank -%}<li><span class="k">{{ b.spec2_k }}</span><span class="val">{{ b.spec2_v }}</span></li>{%- endif -%}
              {%- if b.spec3_k != blank -%}<li><span class="k">{{ b.spec3_k }}</span><span class="val">{{ b.spec3_v }}</span></li>{%- endif -%}
              {%- if b.spec4_k != blank -%}<li><span class="k">{{ b.spec4_k }}</span><span class="val">{{ b.spec4_v }}</span></li>{%- endif -%}
            </ul>

            {%- if b.tags != blank -%}
              <div class="tags">
                {%- assign taglist = b.tags | split: ',' -%}
                {%- for t in taglist -%}<span>{{ t | strip }}</span>{%- endfor -%}
              </div>
            {%- endif -%}

            {%- if p != blank -%}
              {%- assign color_opt = nil -%}
              {%- for opt in p.options_with_values -%}
                {%- assign opt_l = opt.name | downcase -%}
                {%- if opt_l == 'culoare' or opt_l == 'color' or opt_l == 'colour' -%}{%- assign color_opt = opt -%}{%- endif -%}
              {%- endfor -%}
              {%- if color_opt -%}
                <div class="colors" aria-label="Culori disponibile">
                  {%- for val in color_opt.values -%}
                    {%- assign vl = val | downcase | strip -%}
                    {%- assign hex = '#888' -%}
                    {%- case vl -%}
                      {%- when 'albastru', 'blue' -%}{%- assign hex = '#2563eb' -%}
                      {%- when 'auriu', 'gold' -%}{%- assign hex = '#c9a96e' -%}
                      {%- when 'negru', 'black' -%}{%- assign hex = '#1a1a1a' -%}
                    {%- endcase -%}
                    <span class="color-dot" style="background:{{ hex }}" title="{{ val | escape }}" aria-label="{{ val | escape }}"></span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            {%- endif -%}

            <div class="cfoot">
              <div class="price">
                {%- if p != blank -%}{{ p.price | money }}{%- else -%}{{ b.price | default: '—' }}<small data-i18n="products.example">PREȚ EXEMPLU</small>{%- endif -%}
              </div>
              {%- if p != blank -%}
                <a class="add" href="{{ p.url }}"><span data-i18n="products.view">Vezi produsul</span></a>
              {%- else -%}
                <a class="add" href="{{ routes.all_products_collection_url }}"><span data-i18n="products.soon">În curând</span></a>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Produsele. Date reale, imprimate 3D." },
    { "type": "text", "id": "ref", "label": "Reference label", "default": "REF. 01–03" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Shopify product (optional — overrides text below)" },
        { "type": "text", "id": "name", "label": "Name (fallback)", "default": "Produs" },
        { "type": "text", "id": "pn", "label": "Part code", "default": "MA-00" },
        { "type": "textarea", "id": "desc", "label": "Description (fallback)" },
        { "type": "select", "id": "shape", "label": "Silhouette", "options": [
          {"value":"set4","label":"Set (4 bare)"},
          {"value":"bar_long","label":"Bara lunga"},
          {"value":"bar_small","label":"Bara mica"}
        ], "default": "set4" },
        { "type": "header", "content": "Specs" },
        { "type": "text", "id": "spec1_k", "label": "Spec 1 label" },
        { "type": "text", "id": "spec1_v", "label": "Spec 1 value" },
        { "type": "text", "id": "spec2_k", "label": "Spec 2 label" },
        { "type": "text", "id": "spec2_v", "label": "Spec 2 value" },
        { "type": "text", "id": "spec3_k", "label": "Spec 3 label" },
        { "type": "text", "id": "spec3_v", "label": "Spec 3 value" },
        { "type": "text", "id": "spec4_k", "label": "Spec 4 label" },
        { "type": "text", "id": "spec4_v", "label": "Spec 4 value" },
        { "type": "header", "content": "Footer" },
        { "type": "text", "id": "tags", "label": "Tags (comma separated)" },
        { "type": "text", "id": "price", "label": "Example price (fallback)", "default": "—" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Products",
      "blocks": [
        { "type": "product", "settings": {
          "name": "Set Bacuri Nadă Standard", "pn": "MA-BNS", "shape": "set4",
          "desc": "Patru bacuri care se îmbină — 1 XL + 3 mărimi. Nadă sortată, totul pe tava ta.",
          "spec1_k": "Bac XL", "spec1_v": "21 × 13 × 6.5 cm",
          "spec2_k": "3 mărimi", "spec2_v": "15.5 / 10 / 5 cm lățime",
          "spec3_k": "Înălțime", "spec3_v": "6.5 cm",
          "spec4_k": "Perete", "spec4_v": "2 mm",
          "tags": "SET 4, MATTE, GRAVAT", "price": "199 lei" } },
        { "type": "product", "settings": {
          "name": "Suport Wafters v2", "pn": "MA-WAF", "shape": "bar_long",
          "desc": "Suport lung pentru wafters și pop-ups, aliniate și la îndemână în timpul montării.",
          "spec1_k": "Dimensiuni", "spec1_v": "24 × 10 × 3.5 cm",
          "spec2_k": "Lungime utilă", "spec2_v": "24 cm",
          "spec3_k": "Perete", "spec3_v": "2 mm",
          "tags": "WAFTERS, MATTE, GRAVAT", "price": "89 lei" } },
        { "type": "product", "settings": {
          "name": "Suport Gel v2", "pn": "MA-GEL", "shape": "bar_small",
          "desc": "Compact, pentru borcanul de gel/dip — fix, fără răsturnări pe tava laterală.",
          "spec1_k": "Dimensiuni", "spec1_v": "5.2 × 10 × 3.5 cm",
          "spec2_k": "Perete", "spec2_v": "2 mm",
          "tags": "GEL/DIP, MATTE, GRAVAT", "price": "39 lei" } }
      ]
    }
  ]
}
{% endschema %}
